{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@org/source"],
    "baseUrl": ".",
    "paths": {
      "@org/domain/*": ["libs/domain/*/src/index.ts"],
      "@org/application/*": ["libs/application/*/src/index.ts"],
      "@org/infrastructure/*": ["libs/infrastructure/*/src/index.ts"]
    }
  }
}
